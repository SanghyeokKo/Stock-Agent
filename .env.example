# ===== LLM =====
OPENAI_API_KEY=sk-...
ROUTER_MODEL=gpt-4o-mini
MAIN_MODEL=gpt-4o

# ===== News Search =====
TAVILY_API_KEY=tvly-...

# ===== Broker Provider =====
# mock : yfinance/정적 Mock 기반 (KIS 키 발급 대기 중 디버깅용)
# kis  : 한국투자증권 모의투자 Open API
# toss : (Phase 2 예정) 토스증권 API — factory에 클래스 등록만 하면 즉시 교체
BROKER_PROVIDER=kis

# ===== 한국투자증권 (모의투자) =====
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=      # 계좌번호 앞 8자리
KIS_ACCOUNT_PRDT=01  # 계좌상품코드 뒤 2자리

# ===== RAG =====
VECTOR_DB_DIR=.chroma
